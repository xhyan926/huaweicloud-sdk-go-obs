<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO">
    <Appenders>
    	<!-- console appender -->
        <Console name="Console">
            <PatternLayout charset="UTF-8" pattern="[%d{yyyy-MM-dd HH:mm:ss.SSS}][%-5level][TestCase - %X{caseName}][%C][%M,%L][%msg]%n" />
        </Console>
		
		<!-- north interface log -->
        <RollingFile name="NorthInterfaceLogAppender" fileName="${sys:user.dir}/logs/OBS-SDK-Test.interface_north.log"
                     filePattern="${sys:user.dir}/logs/OBS-SDK-Test.interface_north-%i.log" filePermissions="rw-------">
            <PatternLayout charset="UTF-8" pattern="[%d{yyyy-MM-dd HH:mm:ss.SSS}][%-5level][TestCase - %X{caseName}][%C][%M,%L][%msg]%n" />
            <SizeBasedTriggeringPolicy size="20M" />
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>
        
        <!-- south interface log -->
        <RollingFile name="SouthInterfaceLogAppender" fileName="${sys:user.dir}/logs/OBS-SDK-Test.interface_south.log"
                     filePattern="${sys:user.dir}/logs/OBS-SDK-Test.interface_south-%i.log" filePermissions="rw-------">
             <PatternLayout charset="UTF-8" pattern="[%d{yyyy-MM-dd HH:mm:ss.SSS}][%-5level][TestCase - %X{caseName}][%C][%M,%L][%msg]%n" />
            <SizeBasedTriggeringPolicy size="20M" />
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>

        <!-- access log -->
        <RollingFile name="AccessLogAppender" fileName="${sys:user.dir}/logs/OBS-SDK-Test.access.log"
                     filePattern="${sys:user.dir}/logs/OBS-SDK-Test.access-%i.log" filePermissions="rw-------">
            <PatternLayout charset="UTF-8" pattern="[%d{yyyy-MM-dd HH:mm:ss.SSS}][%-5level][TestCase - %X{caseName}][%C][%M,%L][%msg]%n" />
            <SizeBasedTriggeringPolicy size="20M" />
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>
        
    </Appenders>

    <Loggers>
    	<!-- north log -->
        <Logger name="com.obs.services.ObsClient" level="DEBUG"
                additivity="false">
            <AppenderRef ref="NorthInterfaceLogAppender" />
        </Logger>
        
        <!-- south log -->
        <Logger name="com.obs.services.internal.RestStorageService" level="DEBUG"
                additivity="false">
            <AppenderRef ref="SouthInterfaceLogAppender" />
        </Logger>

        <!-- access log -->
        <Logger name="com.obs.log.AccessLogger" level="DEBUG"
                additivity="false">
            <AppenderRef ref="AccessLogAppender" />
        </Logger>
        
        <Logger name="okhttp3.internal.http.RetryAndFollowUpInterceptor" level="DEBUG"
                additivity="false">
            <AppenderRef ref="Console" />
        </Logger>
        
        <!-- console log -->
        <Root level="DEBUG">
            <AppenderRef ref="Console" />
        </Root>
    </Loggers>
</Configuration>