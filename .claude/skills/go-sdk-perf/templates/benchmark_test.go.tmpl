// BenchmarkMemory_{{.TestName}}_{{.Scenario}} 内存性能测试 - {{.Description}}
func BenchmarkMemory_{{.TestName}}_{{.Scenario}}(b *testing.B) {
	// 创建测试客户端
	cfg := config.LoadTestConfig()
	obsClient, _ := obs.New(cfg.AccessKey, cfg.SecretKey, cfg.Endpoint)
	defer obsClient.Close()

	// {{.Description}}
	{{if .CreateTestData}}
	{{.TestDataCreation}}
	{{end}}

	var m runtime.MemStats
	b.ResetTimer()
	b.RunParallel(func(pb *testing.PB) {
		for pb.Next() {
			// 记录内存使用前
			runtime.ReadMemStats(&m)
			memBefore := m.Alloc

			{{.TestCode}}

			// 记录内存使用后
			runtime.ReadMemStats(&m)
			memDelta := m.Alloc - memBefore

			if memDelta > 0 {
				b.Logf("内存分配: %d bytes", memDelta)
			}
		}
	})
}

// BenchmarkResource_{{.TestName}}_{{.Scenario}} 资源监控测试 - {{.Description}}
func BenchmarkResource_{{.TestName}}_{{.Scenario}}(b *testing.B) {
	// 创建测试客户端
	cfg := config.LoadTestConfig()
	obsClient, _ := obs.New(cfg.AccessKey, cfg.SecretKey, cfg.Endpoint)
	defer obsClient.Close()

	// {{.Description}}
	{{if .SetupData}}
	{{.SetupCode}}
	{{end}}

	var m runtime.MemStats
	var cpuUsage float64
	var totalGC uint32
	startTime := time.Now()

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		// 开始时间
		opStart := time.Now()

		// 执行测试
		{{.TestCode}}

		// 记录性能数据
		opDuration := time.Since(opStart)

		// 记录资源使用
		runtime.ReadMemStats(&m)
		totalGC += m.NumGC - totalGC

		// 每100次操作记录一次统计
		if i%100 == 0 {
			cpuUsage = float64(opDuration) / float64(time.Millisecond)
			b.Logf("操作 %d: 时间=%v, 内存=%d MB, GC=%d",
				i, opDuration, m.Alloc/1024/1024, totalGC)
		}
	}

	// 最终统计
	elapsed := time.Since(startTime)
	avgOpTime := float64(elapsed) / float64(b.N) / float64(time.Millisecond)

	b.Logf("=== 资源使用统计 ===")
	b.Logf("总操作数: %d", b.N)
	b.Logf("总时间: %v", elapsed)
	b.Logf("平均操作时间: %.2f ms", avgOpTime)
	b.Logf("最大内存使用: %d MB", m.Alloc/1024/1024)
	b.Logf("GC次数: %d", totalGC)
	b.Logf("CPU使用率: %.2f%%", cpuUsage)
}

